{
    "model": {
        "vocab_size": 3000,
        "d_model": 256,
        "n_heads": 8,
        "n_layers": 4,
        "d_ff": 1024,
        "max_seq_len": 256,
        "dropout": 0.1
    },
    "training": {
        "batch_size": 16,
        "epochs": 30,
        "learning_rate": 5e-4,
        "warmup_steps": 500,
        "grad_clip": 1.0,
        "beta1": 0.9,
        "beta2": 0.999,
        "eps": 1e-8,
        "weight_decay": 0.0
    },
    "data": {
        "train_file": "data_repo/data/train_sequences.json",
        "val_file": "data_repo/data/val_sequences.json",
        "test_file": "data_repo/data/test_sequences.json",
        "tools_file": "data_repo/data/tools.json"
    }
}
